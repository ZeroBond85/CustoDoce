#!/usr/bin/env python
"""
pre-push hook (CustoDoce)
Executa ANTES do push — se falhar, o push NAO acontece.

Resolucao do Python:
  1. Prefere `.venv314/Scripts/python.exe` (Windows) ou `.venv314/bin/python` (WSL).
  2. Fallback: sys.executable (Python que invocou o hook).
  3. Hard-fail se nenhum Python com deps completas for encontrado.

Garante que TODOS os subprocessos usem o MESMO Python com requirements.lock
instalado -> paridade total de ambiente.

Otimizacao (Fase 1):
  - Checks independentes rodam em paralelo (ThreadPoolExecutor).
  - audit_secrets escaneia so o que sera pushado (--since N).
  - sync_docs roda a versao rigorosa (--check --strict) com auto-fix.
  - gh run list e pip-audit tem timeout (rede nao bloqueia o push).

Pular em emergencia: git push --no-verify
"""

from __future__ import annotations

import concurrent.futures as cf
import os
import subprocess
import sys
import time
from pathlib import Path

REPO_ROOT = Path(__file__).parent.parent.resolve()


def _resolve_python() -> str:
    """Resolve Python do projeto.

    Ordem de procura:
    1. Env var CUSTODOCE_PYTHON (override explicito).
    2. <VENV> env var ou ~/custodoce-314/bin/python (WSL/Linux nativo).
    3. .venv314/Scripts/python.exe  (Windows nativo no repo).
    4. .venv314/bin/python          (Linux/WSL nativo no repo).
    5. sys.executable               (fallback final com aviso).
    """
    explicit = os.environ.get("CUSTODOCE_PYTHON")
    if explicit and Path(explicit).exists() and os.access(explicit, os.X_OK):
        print(f"  [python] usando CUSTODOCE_PYTHON: {explicit}", file=sys.stderr)
        return explicit

    home_venvs = [Path.home() / "custodoce-314" / "bin" / "python"]
    candidates = home_venvs + [
        REPO_ROOT / ".venv314" / "Scripts" / "python.exe",
        REPO_ROOT / ".venv314" / "bin" / "python",
    ]
    for candidate in candidates:
        if candidate.exists() and os.access(candidate, os.X_OK):
            print(f"  [python] usando venv: {candidate}", file=sys.stderr)
            return str(candidate)

    print("  [python] AVISO: nenhum venv encontrado (.venv314 ou ~/custodoce-314); fallback para sys.executable", file=sys.stderr)
    return sys.executable


THIS_PYTHON = _resolve_python()


def run(
    cmd: list[str],
    capture: bool = True,
    timeout: int | None = None,
) -> subprocess.CompletedProcess:
    """Executa comando usando o MESMO Python que roda este hook."""
    print(f"  $ {' '.join(cmd)}")
    return subprocess.run(  # noqa: S603 - hook runs only known commands
        cmd,
        cwd=REPO_ROOT,
        capture_output=capture,
        text=True,
        timeout=timeout,
    )


def _compute_since() -> str:
    """Quantos commits serao pushados (desde origin/master)."""
    out = run(["git", "rev-list", "--count", "origin/master..HEAD"], capture=True)
    if out.returncode == 0 and out.stdout.strip().isdigit():
        return out.stdout.strip()
    return "50"  # fallback conservador


# ─── Checks independentes (rodam em paralelo) ────────────────────────────────


def check_audit_secrets() -> tuple[str, subprocess.CompletedProcess]:
    since = _compute_since()
    return "audit_secrets", run(
        [THIS_PYTHON, "scripts/audit_secrets.py", "--strict", "--since", since]
    )


def check_agents_tool() -> tuple[str, subprocess.CompletedProcess]:
    return "agents_tool", run([THIS_PYTHON, "scripts/agents_tool.py", "--check"])


def check_ci_local() -> tuple[str, subprocess.CompletedProcess]:
    return "ci_local", run([THIS_PYTHON, "scripts/ci_local.py", "--no-unit"])


def check_validate_query_columns() -> tuple[str, subprocess.CompletedProcess]:
    return "validate_query_columns", run([THIS_PYTHON, "scripts/validate_query_columns.py"])


def check_audit_df_columns() -> tuple[str, subprocess.CompletedProcess]:
    return "audit_df_columns", run([THIS_PYTHON, "scripts/audit_df_columns.py"])


def check_environment_parity() -> tuple[str, subprocess.CompletedProcess]:
    return "environment_parity", run([THIS_PYTHON, "scripts/check_environment_parity.py"])


def check_schema_mocks() -> tuple[str, subprocess.CompletedProcess]:
    """Gera manifest + roda pytest de mocks (worker dedicado)."""
    gen = run([THIS_PYTHON, "scripts/generate_schema_manifest.py"])
    if gen.returncode != 0:
        return "schema_mocks", gen
    return "schema_mocks", run(
        [
            THIS_PYTHON,
            "-m",
            "pytest",
            "tests/unit/test_validate_mocks_against_manifest.py",
            "-q",
            "--no-header",
        ]
    )


def check_sync_docs() -> tuple[str, subprocess.CompletedProcess]:
    """Self-healing sync pipeline.

    A. Roda ``--check --strict`` (gate truthful).
    B. Se OK: retorna (sync_docs, ok).
    C. Se FAIL: aplica ``python scripts/sync_docs.py`` (``LIVE``, ``TIMESTAMP``,
       ``AUTO``, ``TIMESTAMP_PROTECTED``, ``SNAPSHOT_REFERENCE_LIVE``).
       ``IMMUTABLE`` (ADRs) e ``SNAPSHOT_FROZEN`` são blindados.
    D. Re-rodado ``--check --strict`` por segurança. Se ainda falha, abortar.

    Invariantes protegidos (abort pre-push):
      - Arquivo em ``IMMUTABLE`` (docs/adr/) tocado pelo apply.
      - Arquivo em ``SNAPSHOT_FROZEN`` tocado pelo apply.
      - Arquivo criado (``??`` em git status).
      - Arquivo deletado (``D`` em git status).
    """
    r = run([THIS_PYTHON, "scripts/sync_docs.py", "--check", "--strict"])
    if r.returncode == 0:
        if "[DRIFT]" not in r.stdout:
            return "sync_docs", r
        # [DRIFT] detected in archive docs (SNAPSHOT_REFERENCE_LIVE) despite exit 0.
        # Proceed to self-healing so Raio-X gets updated to local truth.
        print(
            "  [sync_docs] [DRIFT] detectado em archive — aplicando auto-fix",
            file=sys.stderr,
        )

    print(
        "  [sync_docs] gate falhou — tentando self-healing (live apply)",
        file=sys.stderr,
    )

    fix = run([THIS_PYTHON, "scripts/sync_docs.py"])
    if fix.returncode != 0:
        print("  [sync_docs] live apply falhou — abortando pre-push", file=sys.stderr)
        return "sync_docs", fix

    rev_applied = subprocess.run(  # noqa: S603
        ["git", "status", "--porcelain"],
        cwd=REPO_ROOT,
        capture_output=True,
        text=True,
        encoding="utf-8",
        errors="replace",
        timeout=15,
    )
    if rev_applied.returncode != 0:
        print("  [sync_docs] git status falhou pós-apply", file=sys.stderr)
        return "sync_docs", rev_applied

    import json as _json

    try:
        from scripts.doc_sync_policy import DocPolicy, policy_for  # type: ignore
    except Exception as e:
        print(f"  [sync_docs] import policy_for falhou: {e}", file=sys.stderr)
        policy_for = None  # type: ignore

    blocked = []
    eligible_to_add = []
    for line in rev_applied.stdout.splitlines():
        if not line.strip():
            continue
        status, _, path = line.lstrip().partition(" ")
        path = path.strip().rstrip("/")
        if not path.endswith(".md"):
            continue

        status_code = line[:2].strip()
        if status_code == "??":
            blocked.append(f"CRIADO {path} — sync não deve criar arquivos. Remova e re-pushe.")
            continue
        if status_code.startswith("D"):
            blocked.append(f"DELETADO {path} — sync não deve deletar arquivos. Rever antes de continuar.")
            continue

        if policy_for and path.startswith("docs/"):
            try:
                policy = policy_for(path)
            except Exception:
                policy = None
            if policy in (DocPolicy.IMMUTABLE, DocPolicy.SNAPSHOT_FROZEN):
                blocked.append(
                    f"INVARIANT {path} ({policy.value}) modificado manualmente — "
                    "sync nunca toca. Reverter: git checkout -- path/rel"
                )
                continue

        eligible_to_add.append(path)

    if blocked:
        print(
            "  [sync_docs] ABORT — invariantes violadas no tree pós-apply:",
            file=sys.stderr,
        )
        for b in blocked:
            print(f"    {b}", file=sys.stderr)
        rev_empty = subprocess.CompletedProcess(  # noqa: S603
            args=[], returncode=2, stdout="", stderr=""
        )
        return "sync_docs", rev_empty

    for path in eligible_to_add:
        subprocess.run(  # noqa: S603
            ["git", "add", "--", path],
            cwd=REPO_ROOT,
            capture_output=True,
            text=True,
            timeout=15,
        )

    rev = run([THIS_PYTHON, "scripts/sync_docs.py", "--check", "--strict"])
    if rev.returncode != 0:
        print(
            "  [sync_docs] ainda há drift após self-healing — pre-push abortado.",
            "  Revisões pendentes podem estar fora do escopo de auto-fix.",
            sep="\n",
            file=sys.stderr,
        )
    return "sync_docs", rev


PARALLEL_CHECKS = [
    check_audit_secrets,
    check_agents_tool,
    check_ci_local,
    check_validate_query_columns,
    check_audit_df_columns,
    check_schema_mocks,
    check_environment_parity,
    check_sync_docs,
]


def main() -> int:
    start = time.monotonic()
    print("=== pre-push: validando...", file=sys.stderr)

    # [1/4] Working tree limpo (bloqueante)
    print("[1/4] working tree limpo...", file=sys.stderr)
    status = run(["git", "status", "--porcelain"])
    if status.returncode != 0:
        print(f"ERRO: git status falhou: {status.stderr}", file=sys.stderr)
        return 1
    if status.stdout.strip():
        print("ERRO: working tree tem mudancas nao commitadas.", file=sys.stderr)
        print(status.stdout, file=sys.stderr)
        print("Commit ou descarte antes de fazer push.", file=sys.stderr)
        return 1
    print("  [OK] working tree limpo", file=sys.stderr)

    # [2/4] CI status (warn-only, com timeout de rede)
    print("[2/4] CI status check (warn-only)...", file=sys.stderr)
    gh_result = run(
        ["gh", "run", "list", "--branch", "master", "--limit", "3",
         "--json", "conclusion,headBranch,workflowName"],
        timeout=15,
    )
    if gh_result.returncode != 0:
        print("  [AVISO] gh nao autenticado. Rode 'gh auth login' ou defina GH_TOKEN no .env", file=sys.stderr)
        print("  [AVISO] Pulando CI check — push nao bloqueado, mas verifique manualmente.", file=sys.stderr)
    else:
        import json

        try:
            runs = json.loads(gh_result.stdout)
            failures = [r for r in runs if r.get("conclusion") in ("failure", "cancelled")]
            if failures:
                for f in failures:
                    print(f"  [AVISO] CI: {f['workflowName']} ({f['conclusion']})", file=sys.stderr)
                print("  [AVISO] Pipeline CI esta vermelho. Se este push NAO for a correcao,", file=sys.stderr)
                print("  [AVISO] resolva antes. Para ignorar e pushar mesmo assim:", file=sys.stderr)
                print("  [AVISO]   git push --no-verify", file=sys.stderr)
                print("  [AVISO] Continuando (push responsavel)...", file=sys.stderr)
            else:
                print("  [OK] CI: ultimos runs estao verdes", file=sys.stderr)
        except (json.JSONDecodeError, KeyError) as e:
            print(f"  [AVISO] Nao foi possivel interpretar resposta do gh: {e}", file=sys.stderr)

    # [3/4] Checks paralelos (bloqueantes)
    print(f"[3/4] checks paralelos ({len(PARALLEL_CHECKS)} itens)...", file=sys.stderr)
    results: dict[str, subprocess.CompletedProcess] = {}
    with cf.ThreadPoolExecutor(max_workers=len(PARALLEL_CHECKS)) as ex:
        futures = {ex.submit(fn): fn.__name__ for fn in PARALLEL_CHECKS}
        for future in cf.as_completed(futures):
            name, proc = future.result()
            results[name] = proc
            tag = "[OK]" if proc.returncode == 0 else "[FALHA]"
            print(f"  {tag} {name}", file=sys.stderr)

    # [4/4] Resumo
    elapsed = time.monotonic() - start
    print("", file=sys.stderr)
    print(f"=== pre-push: resumo ({elapsed:.1f}s) ===", file=sys.stderr)
    failed = [name for name, proc in results.items() if proc.returncode != 0]
    if failed:
        for name in failed:
            proc = results[name]
            print(f"  [FALHA] {name}", file=sys.stderr)
            if proc.stdout:
                tail = proc.stdout[-1500:]
                print(tail, file=sys.stderr)
        print("", file=sys.stderr)
        print("=== pre-push: FALHOU. Corrija antes de pushar. ===", file=sys.stderr)
        if "sync_docs" in failed:
            print("  sync_docs: rode 'python scripts/sync_docs.py --sync', revise e commite os docs.", file=sys.stderr)
        return 1

    print("=== pre-push: TODOS os checks passaram. Push liberado. ===", file=sys.stderr)
    print("", file=sys.stderr)
    print("💡 Para assistir o CI ate o fim:", file=sys.stderr)
    print("     python scripts/git_push.py [args]", file=sys.stderr)
    print("   Ou configure o alias e use:", file=sys.stderr)
    print("     git config --local alias.pw '!python scripts/git_push.py'", file=sys.stderr)
    print("     git pw [args]", file=sys.stderr)
    print("", file=sys.stderr)
    print("   (git push sem watch continua funcionando normalmente)", file=sys.stderr)
    return 0


if __name__ == "__main__":
    sys.exit(main())
