#!/usr/bin/env python
"""
pre-push hook (CustoDoce)
Executa ANTES do push — se falhar, o push NAO acontece.

Resolucao do Python:
  1. Prefere `.venv314/Scripts/python.exe` (Windows) ou `.venv314/bin/python` (WSL).
  2. Fallback: sys.executable (Python que invocou o hook).
  3. Hard-fail se nenhum Python com deps completas for encontrado.

Garante que TODOS os subprocessos (ci_local.py, agents_tool.py, etc.) usem
o MESMO Python com requirements.lock instalado → paridade total de ambiente.

Pular em emergencia: git push --no-verify
"""
from __future__ import annotations

import os
import subprocess
import sys
from pathlib import Path

REPO_ROOT = Path(__file__).parent.parent.resolve()


def _resolve_python() -> str:
    """Resolve Python do projeto.

    Ordem de procura:
    1. Env var CUSTODOCE_PYTHON (override explicito).
    2. <VENV> env var ou ~/custodoce-314/bin/python (WSL/Linux nativo).
    3. .venv314/Scripts/python.exe  (Windows nativo no repo).
    4. .venv314/bin/python          (Linux/WSL nativo no repo).
    5. sys.executable               (fallback final com aviso).
    """
    explicit = os.environ.get("CUSTODOCE_PYTHON")
    if explicit and Path(explicit).exists() and os.access(explicit, os.X_OK):
        print(f"  [python] usando CUSTODOCE_PYTHON: {explicit}", file=sys.stderr)
        return explicit

    home_venvs = [Path.home() / "custodoce-314" / "bin" / "python"]
    candidates = home_venvs + [
        REPO_ROOT / ".venv314" / "Scripts" / "python.exe",
        REPO_ROOT / ".venv314" / "bin" / "python",
    ]
    for candidate in candidates:
        if candidate.exists() and os.access(candidate, os.X_OK):
            print(f"  [python] usando venv: {candidate}", file=sys.stderr)
            return str(candidate)
    print("  [python] AVISO: nenhum venv encontrado (.venv314 ou ~/custodoce-314); fallback para sys.executable", file=sys.stderr)
    return sys.executable


THIS_PYTHON = _resolve_python()


def run(cmd: list[str], capture: bool = True) -> subprocess.CompletedProcess:
    """Executa comando usando o MESMO Python que roda este hook."""
    print(f"  $ {' '.join(cmd)}")
    return subprocess.run(  # noqa: S603 - hook runs only known commands
        cmd,
        cwd=REPO_ROOT,
        capture_output=capture,
        text=True,
    )


def main() -> int:
    print("=== pre-push: validando...", file=sys.stderr)

    status = run(["git", "status", "--porcelain"])
    if status.returncode != 0:
        print(f"ERRO: git status falhou: {status.stderr}", file=sys.stderr)
        return 1

    if status.stdout.strip():
        print("ERRO: working tree tem mudancas nao commitadas.", file=sys.stderr)
        print(status.stdout, file=sys.stderr)
        print("Commit ou descarte antes de fazer push.", file=sys.stderr)
        return 1

    print("[0/5] CI status check...", file=sys.stderr)
    gh_result = run(["gh", "run", "list", "--branch", "master", "--limit", "3",
                     "--json", "conclusion,headBranch,workflowName"])
    if gh_result.returncode != 0:
        print("  [AVISO] gh nao autenticado. Rode 'gh auth login' ou defina GH_TOKEN no .env", file=sys.stderr)
        print("  [AVISO] Pulando CI check — push nao bloqueado, mas verifique manualmente.", file=sys.stderr)
    else:
        import json
        try:
            runs = json.loads(gh_result.stdout)
            failures = [r for r in runs if r.get("conclusion") in ("failure", "cancelled")]
            if failures:
                for f in failures:
                    print(f"  [FALHA] CI: {f['workflowName']} ({f['conclusion']})", file=sys.stderr)
                print("  [AVISO] Pipeline CI esta vermelho. Se este push NAO for a correcao,", file=sys.stderr)
                print("  [AVISO] resolva antes. Para ignorar e pushar mesmo assim:", file=sys.stderr)
                print("  [AVISO]   git push --no-verify", file=sys.stderr)
                print("  [AVISO] Continuando (push responsavel)...", file=sys.stderr)
            print("  [OK] CI: ultimos runs estao verdes", file=sys.stderr)
        except (json.JSONDecodeError, KeyError) as e:
            print(f"  [AVISO] Nao foi possivel interpretar resposta do gh: {e}", file=sys.stderr)

    print("[1/5] audit_secrets...", file=sys.stderr)
    result = run([THIS_PYTHON, "scripts/audit_secrets.py", "--strict"])
    if result.returncode != 0:
        print("FALHA: secrets detectados no repo. Corrija antes de push.", file=sys.stderr)
        if result.stdout:
            print(result.stdout[:500], file=sys.stderr)
        return 1
    print("[OK] secrets: limpos", file=sys.stderr)

    print("[1.5/5] agents_tool --check (schema)...", file=sys.stderr)
    result = run([THIS_PYTHON, "scripts/agents_tool.py", "--check"])
    if result.returncode != 0:
        print("FALHA: agents_tool --check falhou. Corrija AGENTS.md antes de push.", file=sys.stderr)
        if result.stdout:
            print(result.stdout[-1000:], file=sys.stderr)
        return 1
    print("[OK] AGENTS.md schema valido", file=sys.stderr)

    print("[2/5] ci_local.py...", file=sys.stderr)
    run_unit = os.environ.get("CI_LOCAL_UNIT") == "1"
    ci_args = [THIS_PYTHON, "scripts/ci_local.py"]
    if not run_unit:
        ci_args.append("--no-unit")

    result = run(ci_args)
    if result.returncode != 0:
        print("FALHA: ci_local.py encontrou erros. Corrija antes de push.", file=sys.stderr)
        if result.stdout:
            print(result.stdout[-1000:], file=sys.stderr)
        return 1
    print("[OK] ci_local: limpos", file=sys.stderr)

    print("[3/5] validate_query_columns (schema check)...", file=sys.stderr)
    result = run([THIS_PYTHON, "scripts/validate_query_columns.py"])
    if result.returncode != 0:
        print("FALHA: colunas referenciadas no codigo nao existem no schema real.", file=sys.stderr)
        if result.stdout:
            print(result.stdout[-1500:], file=sys.stderr)
        print("Corrija o codigo OU migre o schema antes de push.", file=sys.stderr)
        return 1
    print("[OK] schema: todas as colunas existem no Supabase", file=sys.stderr)

    print("[3.5/5] audit_df_columns...", file=sys.stderr)
    result = run([THIS_PYTHON, "scripts/audit_df_columns.py"])
    if result.returncode != 0:
        print("FALHA: colunas usadas em DataFrames nao existem no schema ou alias.", file=sys.stderr)
        if result.stdout:
            print(result.stdout[-1500:], file=sys.stderr)
        return 1
    print("[OK] audit_df_columns: DataFrame columns valid", file=sys.stderr)

    print("[3.75/5] schema_manifest + mock validation...", file=sys.stderr)
    result = run([THIS_PYTHON, "scripts/generate_schema_manifest.py"])
    if result.returncode != 0:
        print("FALHA: nao foi possivel gerar schema manifest.", file=sys.stderr)
        return 1
    result = run([THIS_PYTHON, "-m", "pytest", "tests/unit/test_validate_mocks_against_manifest.py", "-q", "--no-header"])
    if result.returncode != 0:
        print("FALHA: mock data nao alinhado com schema real.", file=sys.stderr)
        print("Corrija os mocks em tests/ OU atualize o schema em supabase/consolidated_migration.sql.", file=sys.stderr)
        return 1
    print("[OK] schema_manifest + mock validation: todos os mocks alinhados ao schema real", file=sys.stderr)

    print("[3.875/5] check_environment_parity...", file=sys.stderr)
    result = run([THIS_PYTHON, "scripts/check_environment_parity.py"])
    if result.returncode != 0:
        print("FALHA: ambiente fora de paridade. Corrija antes de push.", file=sys.stderr)
        if result.stdout:
            print(result.stdout[-1500:], file=sys.stderr)
        return 1
    print("[OK] environment parity: Python + lock + platform ok", file=sys.stderr)

    print("[3.9/5] sync_docs --check --strict (aviso)...", file=sys.stderr)
    result = run([THIS_PYTHON, "scripts/sync_docs.py", "--check", "--strict"])
    if result.returncode != 0:
        print("[AVISO] Documentacao dessincronizada. Rode: python scripts/sync_docs.py", file=sys.stderr)
        if result.stdout:
            print(result.stdout[-1500:], file=sys.stderr)
    else:
        print("[OK] docs sincronizadas", file=sys.stderr)

    print("[4/5] test_total_coverage (light, no integration/real)...", file=sys.stderr)
    if os.environ.get("TEST_TOTAL") == "1":
        tt_args = [THIS_PYTHON, "scripts/test_total_coverage.py", "--skip-slow"]
        result = run(tt_args)
        if result.returncode != 0:
            print("FALHA: test_total_coverage encontrou erros. Corrija antes de push.", file=sys.stderr)
            if result.stdout:
                print(result.stdout[-1500:], file=sys.stderr)
            return 1
        print("[OK] test_total_coverage: limpa", file=sys.stderr)
    else:
        print("[SKIP] test_total_coverage (set TEST_TOTAL=1 to enable)", file=sys.stderr)

    print("", file=sys.stderr)
    print("=== pre-push: TODOS os checks passaram. Push liberdo. ===", file=sys.stderr)
    return 0


if __name__ == "__main__":
    sys.exit(main())
