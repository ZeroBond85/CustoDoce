#!/usr/bin/env bash
# pre-push hook (CustoDoce)
# Executa ANTES do push — se falhar, o push NAO acontece.
# Funciona em WSL (onde bash existe) + chama Python do Windows via PATH.
#
# Pular em emergencia: git push --no-verify
#
# O que roda (fast, ~30s):
#   1. Working tree limpo
#   2. audit_secrets --strict (historico + staged)
#   3. ci_local.py --no-unit (config + lint + typecheck)
#
# Para CI completo local: python scripts/ci_local.py --all

set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT"

echo "=== pre-push: validando..." >&2

# 1. Working tree limpo
if [ -n "$(git status --porcelain 2>/dev/null)" ]; then
  echo "ERRO: working tree tem mudancas nao commitadas." >&2
  git status --short >&2
  echo "Commit ou descarte antes de fazer push." >&2
  exit 1
fi

# 2. Audit de secrets (historico + staged)
# Usa python3 (WSL) diretamente — wslpath -w produz Windows path que bash não executa
echo "[1/2] audit_secrets..." >&2
python3 scripts/audit_secrets.py --strict 2>&1 || {
  echo "FALHA: secrets detectados no repo. Corrija antes de push." >&2
  exit 1
}
echo "[OK] secrets: limpos" >&2

# 3. CI local (config + lint + typecheck — sem pytest, mais rapido)
echo "[2/2] ci_local.py --no-unit..." >&2
python3 scripts/ci_local.py --no-unit 2>&1 || {
  echo "FALHA: ci_local.py encontrou erros. Corrija antes de push." >&2
  exit 1
}
echo "[OK] ci_local: limpos" >&2

echo "" >&2
echo "=== pre-push: TODOS os checks passaram. Push liberdo. ===" >&2
exit 0