#!/usr/bin/env python
"""
pre-push hook (CustoDoce)
Executa ANTES do push — se falhar, o push NAO acontece.

Usa sys.executable para garantir o MESMO Python com todos os packages.
Funciona de qualquer shell (PowerShell, cmd, WSL bash).

Pular em emergencia: git push --no-verify
"""
from __future__ import annotations

import os
import subprocess
import sys
from pathlib import Path

REPO_ROOT = Path(__file__).parent.parent.resolve()
THIS_PYTHON = sys.executable


def run(cmd: list[str], capture: bool = True) -> subprocess.CompletedProcess:
    """Executa comando usando o MESMO Python que roda este hook."""
    print(f"  $ {' '.join(cmd)}")
    return subprocess.run(  # noqa: S603 - hook runs only known commands
        cmd,
        cwd=REPO_ROOT,
        capture_output=capture,
        text=True,
    )


def main() -> int:
    print("=== pre-push: validando...", file=sys.stderr)

    status = run(["git", "status", "--porcelain"])
    if status.returncode != 0:
        print(f"ERRO: git status falhou: {status.stderr}", file=sys.stderr)
        return 1

    if status.stdout.strip():
        print("ERRO: working tree tem mudancas nao commitadas.", file=sys.stderr)
        print(status.stdout, file=sys.stderr)
        print("Commit ou descarte antes de fazer push.", file=sys.stderr)
        return 1

    print("[1/2] audit_secrets...", file=sys.stderr)
    result = run([THIS_PYTHON, "scripts/audit_secrets.py", "--strict"])
    if result.returncode != 0:
        print("FALHA: secrets detectados no repo. Corrija antes de push.", file=sys.stderr)
        if result.stdout:
            print(result.stdout[:500], file=sys.stderr)
        return 1
    print("[OK] secrets: limpos", file=sys.stderr)

    print("[1.5/4] agents_tool --check (schema)...", file=sys.stderr)
    result = run([THIS_PYTHON, "scripts/agents_tool.py", "--check"])
    if result.returncode != 0:
        print("FALHA: agents_tool --check falhou. Corrija AGENTS.md antes de push.", file=sys.stderr)
        if result.stdout:
            print(result.stdout[-1000:], file=sys.stderr)
        return 1
    print("[OK] AGENTS.md schema valido", file=sys.stderr)

    print("[2/4] ci_local.py...", file=sys.stderr)
    # Check if user wants to run unit tests (via env var)
    run_unit = os.environ.get("CI_LOCAL_UNIT") == "1"
    ci_args = [THIS_PYTHON, "scripts/ci_local.py"]
    if not run_unit:
        ci_args.append("--no-unit")

    result = run(ci_args)
    if result.returncode != 0:
        print("FALHA: ci_local.py encontrou erros. Corrija antes de push.", file=sys.stderr)
        if result.stdout:
            print(result.stdout[-1000:], file=sys.stderr)
        return 1
    print("[OK] ci_local: limpos", file=sys.stderr)

    print("[3/4] validate_query_columns (schema check)...", file=sys.stderr)
    result = run([THIS_PYTHON, "scripts/validate_query_columns.py"])
    if result.returncode != 0:
        print("FALHA: colunas referenciadas no codigo nao existem no schema real.", file=sys.stderr)
        if result.stdout:
            print(result.stdout[-1500:], file=sys.stderr)
        print("Corrija o codigo OU migre o schema antes de push.", file=sys.stderr)
        return 1
    print("[OK] schema: todas as colunas existem no Supabase", file=sys.stderr)

    print("[4/4] test_total_coverage (light, no integration/real)...", file=sys.stderr)
    # Sprint 4: opt-in full pipeline via TEST_TOTAL opt-in env var.
    # Skip by default to keep pre-push <30s. Set TEST_TOTAL=1 to enable.
    if os.environ.get("TEST_TOTAL") == "1":
        tt_args = [THIS_PYTHON, "scripts/test_total_coverage.py", "--skip-slow"]
        result = run(tt_args)
        if result.returncode != 0:
            print("FALHA: test_total_coverage encontrou erros. Corrija antes de push.", file=sys.stderr)
            if result.stdout:
                print(result.stdout[-1500:], file=sys.stderr)
            return 1
        print("[OK] test_total_coverage: limpa", file=sys.stderr)
    else:
        print("[SKIP] test_total_coverage (set TEST_TOTAL=1 to enable)", file=sys.stderr)

    print("", file=sys.stderr)
    print("=== pre-push: TODOS os checks passaram. Push liberdo. ===", file=sys.stderr)
    return 0


if __name__ == "__main__":
    sys.exit(main())
