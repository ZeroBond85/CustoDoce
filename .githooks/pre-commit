#!/usr/bin/env bash
# Pre-commit hook (CustoDoce) — blindado para committers Windows + POSIX
#
# Layer 1: SECRET GUARD         - BLOQUEIA chave de API em staged
# Layer 1.5: GITIGNORE IMPORTS - BLOQUEIA staged importa gitignored
# Layer 1.7: DETECT-SECRETS    - BLOQUEIA detect-secrets encontrar segredo
# Layer 1.8: RUFF LINT         - BLOQUEIA ruff encontrar erros em .py staged
# Layer 2: DOC SYNC            - BLOQUEIA se codigo mudou sem docs (YES bypass, A auto-sync)
# Layer 3: SIZE GUARD          - BLOQUEIA arquivo >100MB (GitHub rejeita; mais vale parar antes)
# Layer 4: DOC WATCHDOG        - AVISO leve sobre outros docs
# Layer 5: AGENTS SCHEMA       - BLOQUEIA se AGENTS.md/LESSONS.md/REGRAS.md não passarem no schema check (agents_tool --check)
# Layer 8: CRLF GUARD          - BLOQUEIA arquivos texto com CRLF (previne churn de line-ending)
#
# Para pular TODOS os checks:  git commit --no-verify  (usar com consciencia)

set -euo pipefail

# Python/git NATIVO do WSL (definidos cedo; usados em todo o hook).
# Robustez máxima: não dependem de conda, .venv314 nem PATH do Windows.
PY="/usr/bin/python3"
GIT="/usr/bin/git"

STAGED=$("$GIT" diff --cached --name-only --diff-filter=ACM 2>/dev/null || true)

# ----------------------------------------------------------------
# AMBIENTE OBRIGATÓRIO: WSL com Python/git NATIVO do sistema.
# O projeto exige que o commit/push rode no WSL (regra 15 do AGENTS.md).
# Se não for WSL, o hook FAILA claramente — não tenta Windows Python
# (evita o erro WinError 2 e garante paridade total de ambiente).
# O Python nativo do WSL (/usr/bin/python3) é do próprio sistema e
# continua funcionando mesmo se o conda/.venv314 "morrer".
# ----------------------------------------------------------------
_IS_WSL=0
if [ -f /proc/sys/kernel/osrelease ] && grep -qi "microsoft\|wsl" /proc/sys/kernel/osrelease 2>/dev/null; then
  _IS_WSL=1
fi

if [ "$_IS_WSL" -ne "1" ]; then
  echo ""
  echo "🚫 COMMIT BLOQUEADO: este hook deve rodar APENAS no WSL (Linux)."
  echo ""
  echo "O projeto exige paridade total de ambiente (AGENTS.md regra 15)."
  echo "No Windows use WSL para commitar/pushar:"
  echo "  wsl.exe -e bash -c 'cd /mnt/c/Zerobond/Code/CustoDoce && git ...'"
  echo ""
  echo "Se voce esta no WSL mas isto aparece, verifique /proc/sys/kernel/osrelease."
  echo ""
  exit 1
fi

# WSL confirmado: usa Python/git nativo definido no topo do hook.
PY_IMP="$PY"

# ----------------------------------------------------------------
# 1. SECRET GUARD - bloqueante (chave em staged => catastrofe publica)
# ----------------------------------------------------------------
if [ -n "${STAGED:-}" ]; then
  PATTERN='sk-(proj-)?[A-Za-z0-9_-]{20,}|sk-ant-[A-Za-z0-9_-]{20,}|gsk_[A-Za-z0-9]{20,}|sk-or-v1-[A-Za-f0-9]{40,}|hf_[A-Za-z0-9]{20,}|AIza[0-9A-Za-z_-]{35,}|gh[pousr]_[A-Za-z0-9]{36,}|xox[abpr]-[0-9A-Za-z-]{10,}|sk_(live|test)_[A-Za-z0-9]{20,}|-----BEGIN [A-Z ]*PRIVATE KEY-----|"type": *"service_account"|nvapi-[A-Za-z0-9_-]{20,}'

  HITS=$("$GIT" diff --cached -U0 -S "$PATTERN" --pickaxe-regex 2>/dev/null \
    | grep -E '^\+[^+]' \
    | grep -E "$PATTERN" \
    | grep -vE '^\+\+\+' \
    | grep -vE '^-' \
    | grep -vE 'tests/unit/test_audit_secrets\.py' \
    || true)

  if [ -n "$HITS" ]; then
    echo ""
    echo "🚨 COMMIT BLOQUEADO: possivel segredo de API detectado nos arquivos staged."
    echo ""
    echo "Matches (primeiros 20):"
    echo "$HITS" | head -20
    echo ""
    echo "Acoes:"
    echo "  - Mova a chave para .env (local) ou GitHub Secrets (CI)"
    echo "  - Substitua no arquivo por referencia: os.environ['OPENAI_API_KEY']"
    echo "  - Re-stage e tente novamente"
    echo "Bypass de emergencia: git commit --no-verify (NAO recomendado)"
    echo ""
    exit 1
  fi
fi

# ----------------------------------------------------------------
# 1.5. GITIGNORE IMPORTS GUARD - bloqueia se importa arquivo gitignored
# ----------------------------------------------------------------
if [ -n "${STAGED:-}" ]; then
  # PY_IMP ja aponta para o Python nativo do WSL (definido no topo).
  if [ -n "$PY_IMP" ] && [ -f "scripts/check_gitignore_imports.py" ]; then
    if ! "$PY_IMP" scripts/check_gitignore_imports.py; then
      exit 1
    fi
  fi
fi

# ----------------------------------------------------------------
# 1.7. DETECT-SECRETS - bloqueia se staged contem segredos detectaveis
# ----------------------------------------------------------------
if [ -n "${STAGED:-}" ]; then
  if command -v detect-secrets &>/dev/null; then
    SCAN_OUT=$(detect-secrets scan --list-all "$STAGED" 2>/dev/null || true)
    if echo "$SCAN_OUT" | grep -qE '"is_secret": ?true'; then
      echo ""
      echo "🚨 COMMIT BLOQUEADO: detect-secrets encontrou segredos nos arquivos staged."
      echo "$SCAN_OUT" | python -c "import sys,json; d=json.load(sys.stdin); [print(f'  {f}: {s[\"type\"]}') for f in d.get('results',{}) for s in d['results'][f]]" 2>/dev/null || echo "$SCAN_OUT"
      echo ""
      echo "Se for falso positivo: detect-secrets audit --update .secrets.baseline"
      exit 1
    fi
  fi
fi

# ----------------------------------------------------------------
# 1.8. RUFF LINT - BLOQUEIA se ruff encontrar erros em .py staged
# ----------------------------------------------------------------
if [ -n "${STAGED:-}" ]; then
  PY_STAGED=$(echo "$STAGED" | tr ' ' '\n' | grep -E '\.py$' || true)
  if [ -n "$PY_STAGED" ]; then
    # Resolve venv Python (mesma logica do pre-push)
    RUFF_PY=""
    for CAND in ".venv314/Scripts/python.exe" ".venv314/Scripts/python" ".venv314/bin/python"; do
      if [ -f "$CAND" ]; then
        RUFF_PY="$CAND"
        break
      fi
    done
    if [ -z "$RUFF_PY" ] && [ -n "$PY" ]; then
      RUFF_PY="$PY"
    fi
    if [ -z "$RUFF_PY" ]; then
      command -v python3 &>/dev/null && RUFF_PY="python3" || RUFF_PY="python"
    fi
    RUFF_OUTPUT=$("$RUFF_PY" -m ruff check --quiet $PY_STAGED 2>&1 || true)
    if [ -n "$RUFF_OUTPUT" ]; then
      echo ""
      echo "🚨 COMMIT BLOQUEADO: Erros de lint (ruff) nos arquivos staged:"
      echo ""
      echo "$RUFF_OUTPUT"
      echo ""
      echo "Para auto-fix: ruff check --fix $(find .venv* -name python -o -name python.exe 2>/dev/null | head -1) -m ruff check --fix $PY_STAGED"
      echo "Ou 'git commit --no-verify' para emergencia (NAO recomendado)"
      echo ""
      exit 1
    fi
  fi
fi

# ----------------------------------------------------------------
# 2. DOC SYNC - AVISA se codigo mudou sem docs (non-interactive por default)
# ----------------------------------------------------------------
CODE_PATTERNS='^(services|scrapers|parsers|telegram_bot|dashboard|admin)/|main\.py$|^\.github/workflows/|^config/|^tests/'
DOC_REQUIRED='^docs/changelog\.md$|^README\.md$|^CUSTO_DOCE_RAIO_X\.md$|^RAIO-X_CUSTO_DOCE_RESUMIDO\.md$'

# Force interactive mode: CUSTODOCE_DOC_SYNC_INTERACTIVE=1
FORCE_INTERACTIVE="${CUSTODOCE_DOC_SYNC_INTERACTIVE:-0}"

if echo "${STAGED:-}" | grep -qE "$CODE_PATTERNS"; then
  if ! echo "${STAGED:-}" | grep -qE "$DOC_REQUIRED"; then
    echo ""
    echo "💡 [AVISO] Codigo de producao alterado sem docs sincronizados."
    echo ""
    echo "Arquivos de codigo staged:"
    echo "$STAGED" | grep -E "$CODE_PATTERNS"
    echo ""
    echo "Sugestao: stagear pelo menos um dos:"
    echo "  - docs/changelog.md (sempre que alterou ciclo de release)"
    echo "  - README.md (mudancas visiveis ao usuario)"
    echo "  - CUSTO_DOCE_RAIO_X.md / RAIO-X_CUSTO_DOCE_RESUMIDO.md (referencia interna)"
    echo ""
    if [ "$FORCE_INTERACTIVE" = "1" ] && [ -t 0 ] && read -r CONFIRM 2>/dev/null; then
      case "$CONFIRM" in
        [Aa])
          echo "[INFO] Rodando sync_docs.py..."
          if [ -n "$PY" ] && [ -f "scripts/sync_docs.py" ]; then
            SYNC_OUTPUT=$("$PY" scripts/sync_docs.py 2>&1) || true
            echo "$SYNC_OUTPUT"
            MODIFIED=$(echo "$SYNC_OUTPUT" | grep -E "^(MODIFIED|CREATE|UPDATE|->)" || true)
            if [ -n "$MODIFIED" ]; then
              echo ""
              echo "📝 Arquivos alterados pelo sync_docs.py (revise e stageie manualmente):"
              echo "$MODIFIED"
            fi
          else
            echo "[WARN] scripts/sync_docs.py nao encontrado ou Python indisponivel"
          fi
          echo "Cancelado. Revise os arquivos alterados e commite novamente."
          exit 1
          ;;
        [Cc])
          echo "Cancelado. Ajuste os docs e commite novamente."
          exit 1
          ;;
        *)
          echo "[AVISO] Continuando sem docs"
          ;;
      esac
    else
      echo "[AVISO] Continuando sem docs (non-interactive mode). Para modo interativo: export CUSTODOCE_DOC_SYNC_INTERACTIVE=1"
    fi
  fi
fi

# ----------------------------------------------------------------
# 2.5 DOC SYNC --strict check - AVISO se sync_docs.py --check falhar
# ----------------------------------------------------------------
if [ -n "$PY" ] && [ -f "scripts/sync_docs.py" ]; then
  SYNC_RESULT=$("$PY" scripts/sync_docs.py --check --strict 2>&1) || true
  if echo "$SYNC_RESULT" | grep -q "\[FAIL\]"; then
    echo ""
    echo "📄 [AVISO] Documentacao desatualizada detectada:"
    echo "$SYNC_RESULT" | grep -E "(HIGH|MEDIUM|\[FAIL\]|\.md:\d+)" | head -10
    echo ""
    echo "  Execute 'python scripts/sync_docs.py' para corrigir automaticamente"
    echo "  Ou 'git commit --no-verify' para pular (NAO recomendado)"
    echo ""
  fi
fi

# ----------------------------------------------------------------
# 3. SIZE GUARD - BLOQUEIA arquivo >100MB (GitHub rejeita de qualquer jeito)
# ----------------------------------------------------------------
OIFS="$IFS"
IFS=$'\n'
for FILE in $STAGED; do
  IFS="$OIFS"
  if [ -f "$FILE" ]; then
    SIZE=$(stat -c%s "$FILE" 2>/dev/null || ls -la "$FILE" 2>/dev/null | awk '{print $5}')
    if [ -n "$SIZE" ] && [ "$SIZE" -gt 104857600 ]; then
      SIZE_MB=$((SIZE / 1048576))
      echo ""
      echo "🚨 COMMIT BLOQUEADO: arquivo >100MB: $FILE ($SIZE_MB MB)."
      echo "GitHub nao aceita arquivos >100MB. Use Git LFS ou adicione em .gitignore."
      echo ""
      exit 1
    fi
  fi
done
IFS="$OIFS"

# ----------------------------------------------------------------
# 4. DOC WATCHDOG - AVISO leve
# ----------------------------------------------------------------
TEST_PATTERNS='^tests/'
if echo "${STAGED:-}" | grep -qE "$TEST_PATTERNS"; then
  if ! echo "${STAGED:-}" | grep -q 'tests/README.md'; then
    echo ""
    echo "💡 [AVISO] tests/* alterado. Considere atualizar tests/README.md."
    echo ""
  fi
fi

# ----------------------------------------------------------------
# 5. AGENTS SCHEMA - bloqueante se AGENTS.md/LESSONS.md/REGRAS.md estiverem staged e invalidos (agents_tool --check)
# ----------------------------------------------------------------
if echo "${STAGED:-}" | grep -q 'AGENTS\.md$'; then
  if [ -n "$PY" ] && [ -f "scripts/agents_tool.py" ] && [ -f "config/agents_schema.yaml" ]; then
    AGENTS_RESULT=$("$PY" scripts/agents_tool.py --check 2>&1) || true
    if echo "$AGENTS_RESULT" | grep -q "\[FAIL\]"; then
      echo ""
      echo "🚨 COMMIT BLOQUEADO: AGENTS.md nao passa no schema check."
      echo "$AGENTS_RESULT" | grep "\[FAIL\]" | head -10
      echo ""
      echo "Execute 'python scripts/agents_tool.py --check' para ver os problemas"
      echo "Ou 'git commit --no-verify' para pular (NAO recomendado)"
      echo ""
      exit 1
    fi
  fi
fi

# ----------------------------------------------------------------
# 5.5 MD AUTO-COMPRESS - BLOQUEIA se MD staged tem seções candidatas a archive
#     Sempre roda em dry-run. Auto-fix: python scripts/md_auto_compress.py compress --apply
#     Bypass: git commit --no-verify
# ----------------------------------------------------------------
if echo "${STAGED:-}" | grep -qiE '(LESSONS|REGRAS)\.md$'; then
  if [ -n "$PY" ] && [ -f "scripts/md_auto_compress.py" ] && [ -f "config/scoring_config.yaml" ]; then
    MD_COMPRESS_OUT=$("$PY" scripts/md_auto_compress.py compress --dry-run 2>&1) || true
    if echo "$MD_COMPRESS_OUT" | grep -qE "(archived|candidate|🗄️|archive)"; then
      echo ""
      echo "📦 [AVISO] MD Auto-Compress detectou secoes candidatas a archive:"
      echo "$MD_COMPRESS_OUT" | grep -E "(archived|candidate|🗄️|archive|score=)" | head -10
      echo ""
      echo "Para auto-arquivar: python scripts/md_auto_compress.py compress --apply"
      echo "Ou 'git commit --no-verify' para pular (NAO recomendado)"
      echo ""
    fi
  fi
fi

# ----------------------------------------------------------------
# 6. SKILL DRIFT - BLOQUEIA se .opencode/skills/ mudou sem sync_docs --check passar
# ----------------------------------------------------------------
if echo "${STAGED:-}" | grep -qE '^\.opencode/skills/'; then
  if [ -n "$PY" ] && [ -f "scripts/sync_docs.py" ]; then
    SYNC_CHECK=$("$PY" scripts/sync_docs.py --check --strict --experimental 2>&1) || true
    if echo "$SYNC_CHECK" | grep -qE "\[FAIL\]|drift|out of sync"; then
      echo ""
      echo "🚨 COMMIT BLOQUEADO: .opencode/skills/ alterado sem sync_docs alinhado."
      echo ""
      echo "Alteracoes detectadas:"
      echo "$STAGED" | grep -E '^\.opencode/skills/'
      echo ""
      echo "$SYNC_CHECK" | grep -E "\[FAIL\]|drift|out of sync" | head -10
      echo ""
      echo "Execute 'python scripts/sync_docs.py --sync' para regenerar docs"
      echo "Ou 'git commit --no-verify' para pular (NAO recomendado)"
      echo ""
      exit 1
    fi
  fi
fi

# ----------------------------------------------------------------
# 7. RESIDUE GUARD - BLOQUEIA commit com artefatos de runtime no stage
# ----------------------------------------------------------------
if [ -n "${STAGED:-}" ]; then
  RESIDUE_PATTERNS='\.whl$|^miniconda\.sh$|^pyenv_bashrc\.txt$|^C\?Usersericsf/|^CustoDoce\.7z$|\.archive/sanitize/|^data/check_.*\.py$|^data/wf_detail\.py$|^data/dispatch\.json$|^check_alerts\.py$|^check_flyers\.py$|^check_ingredients\.py$|^debug_alert\.py$|^data/audit/|^data/skills_backup/|^skills-lock\.json$|^scrapers/[A-Za-z0-9]{8,}$'
  RESIDUE_HITS=$(echo "$STAGED" | grep -E "$RESIDUE_PATTERNS" || true)
  if [ -n "$RESIDUE_HITS" ]; then
    echo ""
    echo "🚨 COMMIT BLOQUEADO: artefatos de runtime detectados nos arquivos staged."
    echo ""
    echo "Os seguintes arquivos nao devem ser commitados:"
    echo "$RESIDUE_HITS"
    echo ""
    echo "Acoes:"
    echo "  - Rode: python scripts/sanitize.py --execute --quick"
    echo "  - Se o arquivo e intencional, remova-o destas listas em .gitignore"
    echo "  - Ou use 'git commit --no-verify' para emergencia (NAO recomendado)"
    echo ""
    exit 1
  fi
fi

# ----------------------------------------------------------------
# 8. CRLF INFO — Aviso informativo se arquivo texto tiver CRLF
#    A solucao de raiz para Windows e core.autocrlf=true (Git converte
#    CRLF->LF no staging silenciosamente). Este check e apenas um aviso
#    caso algo inesperado passe.
# ----------------------------------------------------------------
if [ -n "${STAGED:-}" ]; then
  CRLF_FILES=""
  OIFS="$IFS"
  IFS=$'\n'
  for FILE in $STAGED; do
    IFS="$OIFS"
    case "$FILE" in
      *.py|*.md|*.yml|*.yaml|*.json|*.toml|*.sh|*.txt|*.ini|*.cfg|*.bash|*.lock)
        if [ -f "$FILE" ] && od -An -tx1 "$FILE" 2>/dev/null | grep -qw '0d'; then
          CRLF_FILES="${CRLF_FILES}${CRLF_FILES:+\n}  $FILE"
        fi
        ;;
    esac
  done
  IFS="$OIFS"
  if [ -n "$CRLF_FILES" ]; then
    echo ""
    echo "ℹ️  [INFO] CRLF detectado em arquivos staged (autocrlf=true converte para LF):"
    echo -e "$CRLF_FILES"
    echo ""
  fi
fi

# ----------------------------------------------------------------
# 9. WINDOWS-ONLY PACKAGES GUARD — Bloqueia commit de lock files
#    gerados no Windows (colorama, tzdata, etc.)
#    LESSONS.md #52, REGRAS.md regra 5.
#    Lock files DEVEM ser gerados em WSL/Linux (custodoce-314).
# ----------------------------------------------------------------
WIN_ONLY_PKGS="colorama|tzdata|pywin32|pywin32-ctypes|win32api|win32con|winerror|pywinpty"
if [ -n "${STAGED:-}" ]; then
  LOCK_HITS=""
  OIFS="$IFS"
  IFS=$'\n'
  for FILE in $STAGED; do
    IFS="$OIFS"
    case "$FILE" in
      requirements*.lock)
        if [ -f "$FILE" ]; then
          HITS=$(grep -nE "^(${WIN_ONLY_PKGS})==" "$FILE" 2>/dev/null || true)
          if [ -n "$HITS" ]; then
            LOCK_HITS="${LOCK_HITS}${LOCK_HITS:+\n}  $FILE:\n$HITS"
          fi
        fi
        ;;
    esac
  done
  IFS="$OIFS"
  if [ -n "$LOCK_HITS" ]; then
    echo ""
    echo "❌  [BLOCKED] Pacotes Windows-only detectados em lock files staged:"
    echo -e "$LOCK_HITS"
    echo ""
    echo "Lock files DEVEM ser gerados em WSL/Linux (custodoce-314), NUNCA no Windows."
    echo "Veja: LESSONS.md #52, REGRAS.md regra 5."
    echo ""
    echo "Acoes:"
    echo "  - Regenere os lock files em WSL:"
    echo "    cd /mnt/c/Zerobond/Code/CustoDoce"
    echo "    conda activate custodoce-314"
    echo "    PIP_EXTRA_INDEX_URL=https://download.pytorch.org/whl/cpu pip-compile --allow-unsafe --output-file=requirements-prod.lock requirements-prod.in"
    echo "  - Ou use 'git commit --no-verify' para emergencia (NAO recomendado)"
    echo ""
    exit 1
  fi
fi

exit 0
